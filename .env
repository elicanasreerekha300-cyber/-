# 1. 区块链节点地址 (RPC URL)
# 去 Alchemy (https://www.alchemy.com/) 注册个免费号，创建一个 App (选 Ethereum Sepolia)，把 HTTP URL 粘在这里
RPC_URL=http://127.0.0.1:8545/

# 2. 管理员私钥 (Admin Private Key)
# 打开你的 MetaMask 插件 -> 点击三个点 -> 账户详情 -> 导出私钥
# ⚠️ 注意：为了安全，建议你专门新建一个没钱的测试账号来做这个，不要用有主网资产的账号！
# 粘贴时不要带前面的 0x (如果有的话)
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# 3. 智能合约地址
# 这是你同学之前部署好的合约地址 (如果她是在 Sepolia 测试网部署的)
# 如果她是在本地 Ganache 部署的，你需要重新部署一个到 Sepolia
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3